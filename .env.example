NODE_ENV=production

# --- Authentication ---
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=supersecretchangeme

# --- Vault encryption ---
# Generate your own master key by running:
#   python3 -c "import os, base64; key = os.urandom(32); print('base64:' + base64.b64encode(key).decode('utf-8'))"
MASTER_VAULT_KEY_V1=base64:qnHTmwYb+uoygIw9MsRMY22vS5YPchY+QOi/E79GAvM=

# --- Neo4j ---
NEO4J_URI_BOLT=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- Frontend ---
# For Docker: the frontend container proxies /api to the api service internally,
# so VITE_API_URL should point to the host-accessible API for build-time embedding.
# For dev (Vite proxy): leave as http://localhost:5001 or http://127.0.0.1:5001
VITE_API_URL=http://localhost:5001

# --- PostgreSQL ---
POSTGRES_USER=flowsint
POSTGRES_PASSWORD=flowsint
POSTGRES_DB=flowsint
# For local (non-Docker) usage: postgres is exposed on host port 5433
DATABASE_URL=postgresql://flowsint:flowsint@localhost:5433/flowsint

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
