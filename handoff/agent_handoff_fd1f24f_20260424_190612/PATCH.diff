+
+# التطوير
+make dev                    # بدء بيئة التطوير
+make db-migrate             # تطبيق الترقيات
+make logs                   # عرض السجلات
+
+# الاختبارات
+make test                   # تشغيل جميع الاختبارات
+make test-core              # اختبارات معينة
+
+# النشر
+make deploy                 # نشر للإنتاج
+```
+
